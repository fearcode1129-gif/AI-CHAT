DATABASE_URL=postgresql://user:password@localhost:5432/ai_chat
AUTH_SECRET=replace_with_a_long_random_secret
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_HTTP_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL_DEFAULT=qwen-plus
DASHSCOPE_MODEL_FAST=qwen-turbo
DASHSCOPE_MODEL_CODE=qwen-coder-plus
DASHSCOPE_MODEL_WRITE=qwen-plus
DASHSCOPE_MODEL_KNOWLEDGE=qwen-plus
DASHSCOPE_MODEL_IMAGE=qwen3-vl-plus
DASHSCOPE_KNOWLEDGE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_IMAGE_GENERATION_MODEL=wan2.6-image
UPLOAD_STORAGE_PROVIDER=local
UPLOAD_LOCAL_DIR=uploads
BLOB_READ_WRITE_TOKEN=
UPLOAD_MAX_FILE_SIZE_MB=20
KNOWLEDGE_TOP_K=3
KNOWLEDGE_SCORE_THRESHOLD=0.15
KNOWLEDGE_MAX_EMBEDDING_INPUT_CHARS=8000
IMAGE_GENERATION_SIZE=1024*1024
IMAGE_GENERATION_MAX_IMAGES=1
IMAGE_GENERATION_WATERMARK=false
IMAGE_GENERATION_POLL_ATTEMPTS=40
IMAGE_GENERATION_POLL_INTERVAL_MS=1500
IMAGE_GENERATION_ENABLE_INTERLEAVE=true
APP_TIMEZONE=Asia/Shanghai
QUOTA_WARNING_THRESHOLD=0.8
QUOTA_DAILY_FREE_TOKENS=20000
QUOTA_DAILY_PRO_TOKENS=500000
QUOTA_DAILY_ENTERPRISE_TOKENS=2000000
